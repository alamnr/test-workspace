<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
 
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>info.ejava.examples</groupId>
        <artifactId>examples-root</artifactId>
        <version>6.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>authn-config-example</artifactId>
    <name>Services::Security::Authn Configuration Example</name>
    <description>The project provides a demonstration of configuring security</description>

    <properties>
         <!-- turn off launch of unwrapped Spring boot server during integration test; using Docker instead  -->
        
        <!-- <skipBootRun>true</skipBootRun> -->

        <layered>true</layered>
        <docker.imageTag>layered</docker.imageTag>
        <!-- configure the fabric8:docker plugin using properties -->
        <my.docker.verbose>true</my.docker.verbose>
        <my.docker.dockerFile>${basedir}/Dockerfile.${docker.imageTag}</my.docker.dockerFile>
        <my.docker.name>${project.artifactId}:${docker.imageTag}</my.docker.name>
        <my.docker.ports.api.port>${server.http.port}:8080</my.docker.ports.api.port>

        <!-- not needed here . Needed in IT test Docker image 
            <my.docker.extraHosts.hosts.host.docker.internal>host.docker.internal:host-gateway</my.docker.extraHosts.hosts.host.docker.internal>
         -->

        <my.docker.wait.url>http://${ejava-parent.docker.hostname}:${server.http.port}/api/hello?name=jim</my.docker.wait.url>


    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>    
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-devtools</artifactId>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>info.ejava.examples.common</groupId>
            <artifactId>ejava-web-util</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- needed to set up TLS for RestTemplate -->
        <dependency>
            <groupId>org.apache.httpcomponents.client5</groupId>
            <artifactId>httpclient5</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.github.hakky54</groupId>
            <artifactId>sslcontext-kickstart-for-apache5</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
            <exclusions>
                <exclusion>
                    <groupId>org.junit.vintage</groupId>
                    <artifactId>junit-vintage-engine</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>

    </dependencies>
    
            

    <build>
        <plugins>
             <!-- At this point the Spring Boot Maven Plugin is ready to do what we need as long as we define 
             the Maven server.http.port property value to use. We can define that statically with a Maven pom.xml
             property, a -Dserver.http.port= #### on the Maven command line, or dynamically with the Maven Build Helper Plugin. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>reserve-network-port</id>
                        <!-- execute during the process-resources Maven phase — which is well before pre-integration-test -->
                        <phase>process-resources</phase> 
                        <goals>
                            <goal>reserve-network-port</goal> <!--  execute the reserve-network-port goal of the plugin -->
                        </goals>
                        <configuration>
                            <portNames> <!-- assigned the identified port to the Maven server.http.port property -->
                                <portName>server.http.port</portName>
                            </portNames>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>  <!--   global configuration applies to all executions -->
                <!--  Executable JAR will not be installed or deployed in any Maven local or remote repository when false -->
                    <attach>${spring-boot.attach}</attach> 
                     <!--  Executable JAR will get a unique suffix identified by classifier i.e. "bootexec"-->
                    <classifier>${spring-boot.classifier}</classifier>
                    <!--  <layers>
                        <enabled>${layered}</enabled>
                    </layers> -->
                </configuration>
                <executions>
                    <execution>
                        <id>build-app</id>
                        <phase>package</phase>
                        <goals>   
                        <!--  spring-boot-maven-plugin:repackage goal executed during the Maven package phase with global configuration -->
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                    <execution>
                         <id>pre-integration-test</id> <!-- each execution must have a unique ID when there is more than one -->
                        <phase>pre-integration-test</phase>  <!-- this execution will be tied to the pre-integration-test phase -->
                        <goals>
                            <goal>start</goal> <!-- this execution will start the server in the background -->
                        </goals>
                        <configuration>
                        <!--     -DskipITs=true will deactivate this execution -->
                            <!-- <skip>${skipITs}</skip> -->
                            <skip>${skipBootRun}</skip>
                             
                            <arguments>  <!-- -server.port is being assigned at runtime and used by server for HTTP listen port -->
                               <argument>--server.port=${server.http.port}</argument>
                            </arguments>
                            <!-- comment the profiles for successful http MVN IT test -->
                             <!-- <profiles>https</profiles> -->
                        </configuration>

                    </execution>
                    <execution>
                        <id>post-integration-test</id> <!-- each execution must have a unique ID-->
                        <phase>post-integration-test</phase>  <!--  this execution will be tied to the post-integration-test phase -->
                        <goals>
                            <goal>stop</goal>   <!--   this execution will stop the running server  -->
                        </goals>
                        <configuration>
                             <!--  -DskipITs=true will deactivate this execution -->
                            <!-- <skip>${skipITs}</skip>  -->
                            <skip>${skipBootRun}</skip>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
           
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <executions>
                    <execution>
                        <id>integration-test</id>
                        <goals>  <!-- activate integration-test goal — automatically binds to integration-test phase -->
                            <goal>integration-test</goal>
                        </goals>
                        <configuration>
                            <systemPropertyVariables combine.children="append">
                                <it.server.host>${ejava-parent.docker.hostname}</it.server.host> 
                                <!--  add a -Dit.server.port=${server.http.port} system property to the execution -->
                                <!-- <it.server.port>${server.http.port}</it.server.port> -->

                            </systemPropertyVariables>
                        </configuration>
                    </execution>
                    <execution>
                        <id>verify</id>
                        <!--  verify Goal Must Be Declared to Report Pass/Fail to Maven Build
                            If the verify goal is not wired into the declaration — the setup, tests, and tear down will occur, 
                            but the build will not evaluate and report the results to Maven. The integration tests will appear to always 
                            pass even if you see test errors reported in the integration-test output. -->
                        <goals> 
                            <goal>verify</goal> <!--  activate verify goal — automatically binds to verify phase -->

                        </goals>
                    </execution>
                </executions>
            </plugin>

             <plugin>
                <groupId>io.fabric8</groupId>
                <artifactId>docker-maven-plugin</artifactId>
                <configuration>
                    <containerNamePattern>%n-%t</containerNamePattern>
                    <images>
                        <image>
                            <name>${project.artifactId}</name>
                            <external>
                                <type>properties</type>
                                <prefix>my.docker</prefix>
                                <mode>override</mode>
                            </external>
                        </image>
                    </images>
                </configuration>
                <executions>
                    <execution>
                        <id>build-image</id>
                        <phase>package</phase>
                        <goals>
                            <goal>build</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>start-container</id>
                        <goals>
                            <goal>start</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>stop-container</id>
                        <goals>
                            <goal>stop</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <!-- <id>it</id>
            <activation>
                <file>
                    <exists>${basedir}/src/test/resources/application-itHttps.properties</exists>
                </file>
            </activation> -->
            <id>no-boot-run</id>
            <properties>
                <skipBootRun>true</skipBootRun>
            </properties>
        </profile>
    </profiles> 
    
</project>